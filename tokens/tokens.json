{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "_meta": {
    "name": "JR Academy / 匠人学院 — Design Tokens (Master Brand)",
    "version": "2.0.0",
    "owner": "JR Academy",
    "tagline": "学 AI 来匠人 · STUDY AI AT JR ACADEMY",
    "subSlogan": "一起成为 AI 时代的匠人 · Be an AI Craftsman.",
    "subtitle": "专业的 AI 学习平台 · 课程 · 实战 · 就业",
    "mascot": "牛小匠 · 红 JR 连帽衫 + 墨镜",
    "mascotRole": "AI 学习伙伴 / 职业成长陪伴官",
    "grid": "4pt",
    "primaryFont": "Plus Jakarta Sans + 思源黑体",
    "source": "design.md + spec-sheet-v2.png (2026-05-13)",
    "subProducts": ["unimate-ai", "cert-master", "job-hunter"]
  },
  "color": {
    "primary": {
      "coral":     { "$value": "#FF4D4F", "$type": "color", "$description": "珊瑚红 — 主 CTA / Default" },
      "coralDeep": { "$value": "#E63946", "$type": "color", "$description": "深红 — Active / Pressed / 强调" }
    },
    "accent": {
      "purple": { "$value": "#7861FF", "$type": "color", "$description": "紫罗兰 — 学习 / AI / Info" },
      "yellow": { "$value": "#FFC94D", "$type": "color", "$description": "明黄 — 成就 / 警告" },
      "mint":   { "$value": "#10B981", "$type": "color", "$description": "薄荷绿 — Success / 完成" }
    },
    "neutral": {
      "ink":      { "$value": "#111111", "$type": "color", "$description": "深黑 — 主文字 / Logo" },
      "ink1":     { "$value": "#1F1F1F", "$type": "color", "$description": "一级标题" },
      "ink2":     { "$value": "#333333", "$type": "color", "$description": "深灰 — 次正文" },
      "slate":    { "$value": "#666666", "$type": "color", "$description": "中灰 — 辅助文字" },
      "mist":     { "$value": "#999999", "$type": "color", "$description": "浅灰 — placeholder / disabled" },
      "fog":      { "$value": "#D5D5D5", "$type": "color", "$description": "流灰 — border / divider（暖调）" },
      "fog2":     { "$value": "#E5E7EB", "$type": "color", "$description": "浅 fog — 备选边框" },
      "canvas":   { "$value": "#FAFAF2", "$type": "color", "$description": "米白 — 页面默认 bg（v2 升级 from #F5F6F7）" },
      "canvas2":  { "$value": "#F5F6F7", "$type": "color", "$description": "浅灰 bg — input / 次背景" },
      "white":    { "$value": "#FFFFFF", "$type": "color" }
    },
    "wash": {
      "coral":  { "$value": "#FFEEEE", "$type": "color", "$description": "重要 chip / alert bg" },
      "purple": { "$value": "#EFEBFF", "$type": "color" },
      "yellow": { "$value": "#FFF6DA", "$type": "color" },
      "mint":   { "$value": "#D6F4E5", "$type": "color" }
    },
    "semantic": {
      "success": { "$value": "{color.accent.mint}",     "$type": "color" },
      "warning": { "$value": "{color.accent.yellow}",   "$type": "color" },
      "danger":  { "$value": "{color.primary.coral}",   "$type": "color" },
      "info":    { "$value": "{color.accent.purple}",   "$type": "color", "$description": "用紫不用蓝（区别于 Job Hunter）" }
    },
    "logoGradient": {
      "boxOrange": { "$value": "#FF7E3B", "$type": "color", "$description": "JR Box 渐变起点 — 仅 logo 用" },
      "boxPink":   { "$value": "#FF3B6F", "$type": "color", "$description": "JR Box 渐变终点 — 仅 logo 用" }
    }
  },
  "radius": {
    "none": { "$value": "0",     "$type": "dimension" },
    "xs":   { "$value": "4px",   "$type": "dimension" },
    "sm":   { "$value": "8px",   "$type": "dimension", "$description": "Button 默认" },
    "md":   { "$value": "12px",  "$type": "dimension", "$description": "大按钮 / 大输入框" },
    "lg":   { "$value": "16px",  "$type": "dimension", "$description": "Card 默认" },
    "xl":   { "$value": "20px",  "$type": "dimension" },
    "2xl":  { "$value": "24px",  "$type": "dimension", "$description": "Hero / Modal" },
    "3xl":  { "$value": "32px",  "$type": "dimension" },
    "4xl":  { "$value": "40px",  "$type": "dimension" },
    "full": { "$value": "9999px","$type": "dimension", "$description": "Pill / avatar / chip" }
  },
  "spacing": {
    "1":  { "$value": "4px",   "$type": "dimension" },
    "2":  { "$value": "8px",   "$type": "dimension" },
    "3":  { "$value": "12px",  "$type": "dimension" },
    "4":  { "$value": "16px",  "$type": "dimension" },
    "6":  { "$value": "24px",  "$type": "dimension" },
    "8":  { "$value": "32px",  "$type": "dimension" },
    "10": { "$value": "40px",  "$type": "dimension" },
    "12": { "$value": "48px",  "$type": "dimension" },
    "14": { "$value": "56px",  "$type": "dimension" },
    "16": { "$value": "64px",  "$type": "dimension" },
    "20": { "$value": "80px",  "$type": "dimension" },
    "24": { "$value": "96px",  "$type": "dimension" },
    "32": { "$value": "128px", "$type": "dimension" }
  },
  "layout": {
    "containerMobile":  { "$value": "375px",  "$type": "dimension" },
    "containerTablet":  { "$value": "768px",  "$type": "dimension" },
    "containerDesktop": { "$value": "1200px", "$type": "dimension" },
    "containerWide":    { "$value": "1440px", "$type": "dimension" }
  },
  "shadow": {
    "none":     { "$value": "none",                              "$type": "shadow", "$description": "无阴影" },
    "sm":       { "$value": "0 1px 2px rgba(17,17,17,0.04)",     "$type": "shadow", "$description": "轻 / inline" },
    "md":       { "$value": "0 4px 12px rgba(17,17,17,0.08)",    "$type": "shadow", "$description": "柔和 / Card 默认" },
    "lg":       { "$value": "0 8px 24px rgba(17,17,17,0.10)",    "$type": "shadow", "$description": "中等" },
    "xl":       { "$value": "0 12px 28px rgba(17,17,17,0.12)",   "$type": "shadow", "$description": "浮显 / Modal" },
    "redGlow":  { "$value": "0 8px 20px rgba(255,77,79,0.32)",   "$type": "shadow", "$description": "Primary CTA 发光" },
    "purpleGlow":{ "$value": "0 8px 20px rgba(120,97,255,0.30)", "$type": "shadow" }
  },
  "font": {
    "family": {
      "sans": {
        "$value": "'Plus Jakarta Sans', 'Source Han Sans SC', '思源黑体', 'PingFang SC', 'Microsoft YaHei', system-ui, -apple-system, sans-serif",
        "$type": "fontFamily"
      },
      "mono": {
        "$value": "'JetBrains Mono', 'SF Mono', Menlo, Consolas, monospace",
        "$type": "fontFamily"
      }
    },
    "size": {
      "h1":       { "$value": "48px", "$type": "dimension", "$description": "大标题 / Hero (v2 升级 from 32)" },
      "h2":       { "$value": "32px", "$type": "dimension", "$description": "页面标题 (v2 升级 from 24)" },
      "h3":       { "$value": "20px", "$type": "dimension", "$description": "区块标题" },
      "body1":    { "$value": "16px", "$type": "dimension", "$description": "正文" },
      "body2":    { "$value": "14px", "$type": "dimension", "$description": "次正文 / 列表" },
      "caption":  { "$value": "12px", "$type": "dimension", "$description": "辅助 / metadata" },
      "btnLg":    { "$value": "16px", "$type": "dimension", "$description": "大按钮 - Bold" },
      "btnMd":    { "$value": "14px", "$type": "dimension", "$description": "中按钮 - Medium" },
      "btnText":  { "$value": "14px", "$type": "dimension", "$description": "文本按钮 - Regular" }
    },
    "weight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" }
    },
    "lineHeight": {
      "heading": { "$value": "1.3", "$type": "number" },
      "body":    { "$value": "1.6", "$type": "number" }
    }
  },
  "motion": {
    "duration": {
      "fast":   { "$value": "120ms", "$type": "duration" },
      "base":   { "$value": "200ms", "$type": "duration" },
      "slow":   { "$value": "320ms", "$type": "duration" }
    },
    "easing": {
      "standard": { "$value": "cubic-bezier(0.2, 0.8, 0.2, 1)",   "$type": "cubicBezier" },
      "spring":   { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
    }
  },
  "mascot": {
    "expressions": [
      "happy",
      "thinking",
      "studying",
      "sprint",
      "teaching",
      "celebration"
    ],
    "_note": "v2: 6 个标准表情（开心 / 思考 / 学习中 / 冲刺 / 讲解中 / 庆祝）。原 spec.md 的 11 视图 + 8 动作 拓展库见 assets/mascot/{official,emojis,busts,lifestyle,working,outfits,variants}。"
  },
  "featurePills": {
    "courseQuality":    "优质课程 · 系统化学习",
    "projectPractice":  "项目实战 · 学以致用",
    "aiAssist":         "AI 助学 · 智能陪伴",
    "careerGrowth":     "职业发展 · 成就未来"
  },
  "applicationScenes": {
    "aiDiagnostic":     "AI 职业诊断（Landing / Quiz / Result / CTA / 分享）",
    "learningPlatform": "学习平台（首页 / 今日任务 / 学习计划 / 课程反馈 / 空状态）",
    "communityActivity":"社区与活动（海报 / 表情包 / 周边 / 成就卡）"
  }
}
